pipeline {
	agent any

	options {
		disableConcurrentBuilds()
	}

	stages {
		stage('Prepare Vulkan Builder') {
			steps {
				sh 'DOCKER_DEFAULT_PLATFORM=linux/amd64 DOCKER_BUILDKIT=0 docker build -t vulkan-builder:test0 /workspace/builder/vulkan'
			}
		}

		stage('Build') {
			steps {
				sh '''
					docker run --rm \
						-v "$HOST_WORKSPACE:/workspace" \
						-w /workspace \
						vulkan-builder:test0 \
						sh -lc 'mkdir -p build shaders && slangc src/shader.slang -fvk-use-entrypoint-name -target spirv -o shaders/slang.spv && g++ -std=c++20 -Wall -Wextra -pedantic -I"$VULKAN_SDK/include" src/vulkan.cpp -o build/vulkan $(pkg-config --cflags --libs glfw3) -L"$VULKAN_SDK/lib" -lvulkan'
				'''
			}
		}
	}

	post {
		always {
			sh 'docker run --rm -v "$HOST_WORKSPACE:/workspace" -w /workspace vulkan-builder:test0 rm -rf build shaders'
		}
	}
}
